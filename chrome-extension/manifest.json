{
  "manifest_version": 3,
  "name": "Codex Live Wallpaper",
  "description": "YouTube ページからワンクリックでデスクトップ壁紙として再生する",
  "version": "0.1.0",
  "permissions": ["nativeMessaging", "tabs", "storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Codex Live Wallpaper"
  }
}
